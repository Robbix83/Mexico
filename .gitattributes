# Ensure binary files aren't mangled by git's CRLF / line-ending conversion
*.docx binary
*.pptx binary
*.xlsx binary
*.xls binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.sqlite binary
*.zip binary

# Always-LF for source files (so cross-OS clones get consistent line endings)
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
